{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "allowJs": false,
    "types": ["node"],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "src/lib/auth/**/*.ts",
    "src/lib/calculations/**/*.ts",
    "src/lib/clients/**/*.ts",
    "src/lib/kits/**/*.ts",
    "src/lib/pdf/pdfGenerationOperations.ts",
    "src/lib/proposals/**/*.ts",
    "src/lib/public-proposals/**/*.ts",
    "src/lib/validations/auth.schema.ts",
    "src/lib/validations/client.schema.ts",
    "src/lib/validations/proposal.schema.ts",
    "src/types/client.ts",
    "src/types/proposal.ts",
    "src/types/solar.ts",
    "src/types/solarKit.ts",
    "src/types/payback.ts",
    "src/types/pricing.ts",
    "src/types/loadSurvey.ts",
    "src/types/roofLayout.ts",
    "tests/**/*.ts"
  ]
}
